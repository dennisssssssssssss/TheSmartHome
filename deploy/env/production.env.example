ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://127.0.0.1:5000
ASPNETCORE_FORWARDEDHEADERS_ENABLED=true

AllowedHosts=app.example.com
ConnectionStrings__DefaultConnection=Data Source=/var/lib/smarthomemanager/smarthome.db
RuntimePaths__LogsDirectory=/var/log/smarthomemanager
RuntimePaths__DataProtectionKeysDirectory=/var/lib/smarthomemanager/keys

Jwt__Key=replace-with-a-long-random-secret-at-least-32-characters
Jwt__Issuer=SmartHomeApp
Jwt__Audience=SmartHomeUsers

Bootstrap__SeedDemoData=false
Bootstrap__SeedDefaultAdmin=false
Bootstrap__DefaultAdminPassword=

RateLimiting__Global__PermitLimit=240
RateLimiting__Global__WindowSeconds=60
RateLimiting__Global__QueueLimit=0
RateLimiting__Auth__PermitLimit=10
RateLimiting__Auth__WindowSeconds=60
RateLimiting__Auth__QueueLimit=0

Https__RedirectHttp=true
Https__UseHsts=true
Https__HstsMaxAgeDays=180
Https__IncludeSubDomains=false
Https__Preload=false

SecurityHeaders__Enabled=true
Logging__AppMinimumLevel=Information

Cors__AllowedOrigins__0=https://app.example.com
ReverseProxy__KnownProxies__0=127.0.0.1
MatterBridge__BaseUrl=
MatterBridge__ApiKey=
MatterBridge__TimeoutSeconds=10
ModbusBridge__BaseUrl=
ModbusBridge__ApiKey=
ModbusBridge__TimeoutSeconds=10
