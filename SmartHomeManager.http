@SmartHomeManager_HostAddress = http://localhost:5110
@contentType = application/json

### Login and copy the token from the response
POST {{SmartHomeManager_HostAddress}}/api/Auth/login
Content-Type: {{contentType}}

{
  "username": "admin",
  "password": "assist2026"
